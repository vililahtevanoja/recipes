{
  "name": "personal-recipes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:no-apply": "if rg -n --fixed-strings '@apply' src; then echo 'Error: @apply is not allowed'; exit 1; fi",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "lint": "eslint .",
    "format": "concurrently -g 'oxfmt --config .oxfmtrc.jsonc --ignore-path .gitignore .' 'prettier --write .'",
    "format-check": "concurrently -g 'oxfmt --check --config .oxfmtrc.jsonc --ignore-path .gitignore .' 'prettier --check .'",
    "verify": "pnpm format-check && pnpm check:no-apply && pnpm check && pnpm lint && pnpm build"
  },
  "dependencies": {
    "marked": "17.0.5",
    "mdsvex": "0.12.7",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.55.0",
    "@sveltejs/mcp": "0.1.22",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/postcss": "4.2.2",
    "@types/eslint": "9.6.1",
    "@types/node": "25.5.0",
    "autoprefixer": "10.4.27",
    "concurrently": "9.2.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-svelte": "3.16.0",
    "globals": "17.4.0",
    "oxfmt": "0.43.0",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.55.1",
    "svelte-check": "4.4.6",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.3",
    "vitest": "4.1.2",
    "zod": "4.3.6"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "@tailwindcss/oxide"
    ]
  }
}
