{
  "name": "personal-recipes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:no-apply": "if rg -n --fixed-strings '@apply' src; then echo 'Error: @apply is not allowed'; exit 1; fi",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "lint": "eslint .",
    "format": "concurrently -g 'oxfmt --config .oxfmtrc.jsonc --ignore-path .gitignore .' 'prettier --write .'",
    "format-check": "concurrently -g 'oxfmt --check --config .oxfmtrc.jsonc --ignore-path .gitignore .' 'prettier --check .'",
    "verify": "pnpm format-check && pnpm check:no-apply && pnpm check && pnpm lint && pnpm build"
  },
  "dependencies": {
    "marked": "17.0.3",
    "mdsvex": "0.12.6",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.53.4",
    "@sveltejs/mcp": "0.1.20",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/postcss": "4.2.1",
    "@types/eslint": "9.6.1",
    "@types/node": "25.3.3",
    "autoprefixer": "10.4.27",
    "concurrently": "9.2.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-svelte": "3.15.0",
    "globals": "17.4.0",
    "oxfmt": "0.36.0",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.5.0",
    "svelte": "5.53.6",
    "svelte-check": "4.4.4",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "zod": "4.3.6"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "@tailwindcss/oxide"
    ]
  }
}
