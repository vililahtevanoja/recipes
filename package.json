    "@sveltejs/mcp": "0.1.20",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/postcss": "4.1.18",
    "@types/eslint": "9.6.1",
    "@types/node": "24.10.1",
    "autoprefixer": "10.4.24",
    "eslint": "9.39.2",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-svelte": "3.15.0",
    "globals": "16.5.0",
